{
  "name": "lms-backend",
  "version": "1.0.0",
  "description": "LMS Backend with Analytics Engine",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "npx prisma migrate deploy && node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "npx prisma migrate dev",
    "db:push": "npx prisma db push",
    "db:seed": "node src/seed.js",
    "db:studio": "npx prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.12.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^5.12.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}